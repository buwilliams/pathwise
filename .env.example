# Anthropic
ANTHROPIC_API_KEY=

# Twilio (leave blank in dev to use console SMS sender)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Storage
PATHWISE_DATA_DIR=./data

# Server
PATHWISE_HOST=0.0.0.0
PATHWISE_PORT=8000

# OTP
PATHWISE_OTP_TTL_SECONDS=600
PATHWISE_OTP_MAX_PER_HOUR=3
PATHWISE_OTP_MAX_VERIFY_ATTEMPTS=5

# Sessions
PATHWISE_SESSION_TTL_SECONDS=2592000

# LLM
PATHWISE_PLAN_MODEL=claude-opus-4-7
PATHWISE_RESEARCH_MODEL=claude-opus-4-7
